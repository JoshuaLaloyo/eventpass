# ── Database (Neon free tier: https://neon.tech → create project → copy connection string)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ── Auth
# Generate with:  openssl rand -base64 32
AUTH_SECRET="change-me"
# Needed when deployed (e.g. https://eventpass.vercel.app). Localhost works without it.
# AUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST=true

# Optional — Google login (Google Cloud Console → OAuth client, redirect URI: {APP_URL}/api/auth/callback/google)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── App
APP_URL="http://localhost:3000"
PLATFORM_COMMISSION_PERCENT=5

# ── Payments
# "mock" = built-in simulated payments (test the whole loop with no processor account)
# "flutterwave" = real Flutterwave (sandbox or live depending on your keys)
PAYMENT_PROVIDER=mock
# FLW_SECRET_KEY="FLWSECK_TEST-..."
# FLW_SECRET_HASH="any-long-random-string-also-set-in-flutterwave-dashboard"

# ── Email (optional — ticket PDFs by email; Gmail works with an App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="EventPass <you@gmail.com>"

# ── Poster uploads (optional — Cloudinary; without it, paste poster URLs instead)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ── Seed
ADMIN_EMAIL=admin@eventpass.test
ADMIN_PASSWORD=admin12345
SEED_TEST_ACCOUNTS=true
